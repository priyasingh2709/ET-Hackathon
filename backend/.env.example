# Squirrel News - Backend Configuration
# Copy this to .env and fill in your keys

# MongoDB
DATABASE_URL=mongodb://localhost:27017/squirrel_news 
# or we can add a POSTGRES_URL for Postgres if we want to switch to that later

# AI & LLM (Groq is recommended for current implementation)
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GITHUB_TOKEN=your_github_token_here
GITHUB_MODEL_NAME=your_github_model_name_here

#for special features like news summarization, we can add more keys here as needed
RAPIDAPI_KEY=your_rapidapi_key_here 

# News API
# Get one at https://newsapi.org/
NEWSAPI_KEY=your_newsapi_key_here

# Stripe Payments
# Get these from your Stripe Dashboard (Test Mode)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# App Settings
SECRET_KEY=your_jwt_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200
